{
  "review_tiers": {
    "fast": {
      "nudge_threshold": 30,
      "hard_block_threshold": 60
    },
    "regular": {
      "commit_edit_floor": 30
    },
    "cold_read_escalation": {
      "nudge_threshold": 3,
      "hard_block_threshold": 5
    }
  },
  "counters": {
    "discipline_threshold": 50
  },
  "review": {
    "prompt_path": ".claude/skills/adversarial-review/SKILL.md",
    "reviewer": "codex",
    "model": "gpt-5.5",
    "effort": "medium"
  },
  "branch_convention": {
    "trunk_branches": ["master", "main"]
  },
  "plans": {
    "active_plan_pointer": ".claude/active-plan",
    "fallback_glob": ["plans/*.md"]
  },
  "codex": {
    "pr_review_timeout_s": 600
  },
  "logging": {
    "dir": null,
    "retention_days": 14,
    "enabled": true,
    "sweep_throttle_hours": 24
  }
}
