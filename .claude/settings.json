{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "_hooks_note": "Source-repo self-wiring: ADVISORY hooks only, via skills/disciplined-development/hooks/ paths (this repo does NOT symlink its skills into .claude/skills/). The three hard blocks (edit_block, commit_block, pre_pr_review) are deliberately omitted so they don't gate heavy bundle development. See no-self-symlink-skills convention.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/skills/disciplined-development/hooks/discipline_nudge.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/skills/disciplined-development/hooks/edit_counter.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/skills/disciplined-development/hooks/review_nudge.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/skills/disciplined-development/hooks/session_reground.py\""
          }
        ]
      }
    ]
  }
}
