# macOS Finder metadata
.DS_Store

# Python build/runtime cruft from the hook stack
__pycache__/
*.pyc
.pytest_cache/

# Per-project hook runtime state (only created when a consumer runs the hooks)
.dd-state/

# Skill-build subagent transcripts — never re-enter the bundle
baseline-*.md

# Session-local pointer to the current active plan (per-session working state)
.claude/active-plan

# Research harness output — never commit experiment results
research/results.csv
research/runs/
